# ---- LLM brain ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Vibe Prospecting / Explorium data API ----
EXPLORIUM_API_KEY=
EXPLORIUM_BASE_URL=https://api.explorium.ai/v1

# ---- Gmail (Kathy's inbox, OAuth2) ----
# Create an OAuth client in Google Cloud Console (Gmail API enabled),
# then run the one-time consent flow to get a refresh token. See README.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=kathy@yellowpop.com

# ---- Google Sheet lead tracker ----
# Uses the SAME Google OAuth client as Gmail. The refresh token above must be
# minted with the Sheets scope too: re-run the OAuth Playground with BOTH
#   https://www.googleapis.com/auth/gmail.compose
#   https://www.googleapis.com/auth/spreadsheets
# Then create a Google Sheet (owned by / shared to kathy@) and paste its ID
# (the long string in the URL between /d/ and /edit).
SHEETS_SPREADSHEET_ID=
SHEETS_TAB=Leads
SHEETS_COMPANIES_TAB=Companies

# ---- Signage classifier (vision) ----
# Optional. With a SerpAPI key, Kathy looks at real store photos to decide the
# A/B/C signage scenario (via Claude vision). Leave empty to fall back to a
# description-based guess. Get a key at https://serpapi.com.
SERPAPI_KEY=
SIGNAGE_IMAGES=4

# ---- Behavior ----
# Cron (UTC). Default: 13:00 UTC on weekdays.
RUN_CRON=0 13 * * 1-5
ACCOUNTS_PER_RUN=25
CONTACTS_PER_ACCOUNT=5
# draft_only = Kathy writes Gmail drafts a human approves+sends (recommended to start)
# send       = Kathy sends directly (only after deliverability/warm-up)
AUTO_SEND=draft_only
DATA_DIR=./data

# Set DRY_RUN=true to run the full loop with built-in fixtures and NO external
# API calls (no Explorium credits, no emails). Great for first boot / demo.
DRY_RUN=true
